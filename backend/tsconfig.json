{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["ES2020"],

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "types": ["node"],

    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ],

    "sourceMap": true,


  },


  "include": [
    "src/**/*",
    "prisma/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}
